{
  "name": "@streamline/dye2-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "Streamline/DYE2 plugin for bean and grinder management",
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.js -i src/styles/tailwind.css -o src/styles/tailwind.generated.css --minify",
    "build": "npm run build:css && vite build",
    "dev": "vite build --watch",
    "serve": "node dev-server.mjs"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.19",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.0.0"
  }
}
